# .env.example — SteroidDoseR connection configuration template
#
# Copy this file to .env and fill in your site-specific values.
# Never commit .env to version control — it contains credentials.
# .env is already listed in .gitignore.
#
# Usage in R:
#   con <- SteroidDoseR::create_connection_from_env(".env")
#
# All variables are optional when passed directly to create_omop_connection().
# Variables are read in priority order (first non-empty value wins).

# =============================================================================
# REQUIRED
# =============================================================================

# Server hostname or IP address
# SQL Server:  myserver.institution.edu
# PostgreSQL:  localhost
# Databricks:  myworkspace.cloud.databricks.com
SQL_SERVER=

# Database name (top-level catalog)
SQL_DATABASE=

# =============================================================================
# AUTHENTICATION
# =============================================================================

# --- Username / password auth (SQL Server, PostgreSQL, Redshift, Databricks) -
SQL_USER=
SQL_PASSWORD=

# --- Windows AD / integrated security (SQL Server on Windows only) -----------
# Set to "true" to use the current Windows login — no username/password needed.
# For NTLM (cross-platform domain auth), also set SQL_USER and SQL_PASSWORD.
USE_WINDOWS_AUTH=false

# Optional: explicit domain credentials for NTLM auth (overrides SQL_USER/PASSWORD)
# SQL_WINDOWS_USER=DOMAIN\username
# SQL_WINDOWS_PASSWORD=

# --- Databricks token auth ---------------------------------------------------
# Set SQL_USER=token and SQL_PASSWORD to your personal access token, OR supply
# a full JDBC connection string in DB_EXTRA_SETTINGS.
# DATABRICKS_TOKEN=dapi...

# =============================================================================
# DATABASE TYPE
# =============================================================================

# DBMS platform.  Supported values (case-insensitive):
#   sql server   postgresql   redshift   oracle   databricks   spark   bigquery
# Default: sql server
SQL_DBMS=sql server

# Port number.  Defaults applied automatically when omitted:
#   SQL Server: 1433  |  PostgreSQL: 5432  |  Databricks: 443  |  Oracle: 1521  |  Redshift: 5439
# SQL_PORT=1433

# =============================================================================
# OMOP SCHEMA CONFIGURATION
# =============================================================================

# CDM schema.  Use just the schema name (e.g. dbo) — the database name is
# prepended automatically so the full reference becomes DATABASE.dbo.
# Or supply the fully qualified name (e.g. Myositis_OMOP.dbo) to skip
# auto-prefixing.
SQL_CDM_SCHEMA=dbo

# Vocabulary schema (defaults to CDM schema when omitted)
# SQL_VOCABULARY_SCHEMA=dbo

# Results / scratch schema for temp-table emulation (Databricks / Spark)
# SQL_RESULTS_SCHEMA=

# =============================================================================
# JDBC DRIVER
# =============================================================================

# Path to the folder containing JDBC driver JARs.
# Download drivers with: DatabaseConnector::downloadJdbcDrivers("sql server", pathToDriver = "~/jdbc")
# Also set in ~/.Renviron so it is available to all R sessions:
#   JDBC_DRIVER_PATH=/path/to/jdbc
JDBC_DRIVER_PATH=

# =============================================================================
# DATABRICKS / SPARK (only relevant for Databricks connections)
# =============================================================================

# HTTP path for the Databricks SQL warehouse or cluster
# DB_EXTRA_SETTINGS=httpPath=/sql/1.0/warehouses/<warehouse-id>

# Enable Arrow columnar transport for faster data transfer (requires JVM setup)
# ENABLE_ARROW=FALSE

# DatabaseConnector performance tuning
# DATABASE_CONNECTOR_BATCH_SIZE=10000
# DATABASE_CONNECTOR_BULK_UPLOAD=FALSE

# =============================================================================
# EXAMPLE CONFIGURATIONS (uncomment one block)
# =============================================================================

# --- JHU SQL Server (Windows AD) --------------------------------------------
# SQL_DBMS=sql server
# SQL_SERVER=myserver.esm.johnshopkins.edu
# SQL_DATABASE=Myositis_OMOP
# SQL_CDM_SCHEMA=dbo
# USE_WINDOWS_AUTH=true
# JDBC_DRIVER_PATH=C:/jdbc

# --- SQL Server (username / password) ----------------------------------------
# SQL_DBMS=sql server
# SQL_SERVER=myserver.institution.edu
# SQL_DATABASE=OMOP_CDM
# SQL_CDM_SCHEMA=dbo
# SQL_USER=omop_read
# SQL_PASSWORD=changeme
# JDBC_DRIVER_PATH=~/jdbc

# --- PostgreSQL --------------------------------------------------------------
# SQL_DBMS=postgresql
# SQL_SERVER=localhost
# SQL_DATABASE=omop_cdm
# SQL_PORT=5432
# SQL_CDM_SCHEMA=cdm_54
# SQL_USER=omop_user
# SQL_PASSWORD=changeme
# JDBC_DRIVER_PATH=~/jdbc

# --- Databricks --------------------------------------------------------------
# SQL_DBMS=databricks
# SQL_SERVER=myworkspace.cloud.databricks.com
# SQL_DATABASE=hive_metastore
# SQL_CDM_SCHEMA=omop_cdm
# SQL_USER=token
# SQL_PASSWORD=dapi_your_personal_access_token_here
# DB_EXTRA_SETTINGS=httpPath=/sql/1.0/warehouses/abc123
# JDBC_DRIVER_PATH=~/jdbc

# --- Amazon Redshift ---------------------------------------------------------
# SQL_DBMS=redshift
# SQL_SERVER=myworkgroup.123456789.us-east-1.redshift-serverless.amazonaws.com
# SQL_DATABASE=omop
# SQL_PORT=5439
# SQL_CDM_SCHEMA=cdm
# SQL_USER=omop_user
# SQL_PASSWORD=changeme
# JDBC_DRIVER_PATH=~/jdbc
